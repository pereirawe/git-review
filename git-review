#!/usr/bin/env bash
# =============================================================================
# git-review — Code Review via OpenAI API
# Uso: git-review [branch-base]
#      Se omitido, detecta automaticamente main ou master.
# =============================================================================

set -euo pipefail

VERSION="1.0.7"

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" >/dev/null 2>&1 && pwd)"
CONFIG_FILE="${GIT_REVIEW_CONFIG:-$HOME/.local/share/git-review/git-review.conf}"
SYSTEM_PROMPT_FILE="${SYSTEM_PROMPT_FILE:-$SCRIPT_DIR/system_prompt.txt}"
DESCRIPTION_FILE="${DESCRIPTION_FILE:-$SCRIPT_DIR/DESCRIPTION.md}"

API_PROVIDER="${API_PROVIDER:-openai}"

OPENAI_API_KEY="${OPENAI_API_KEY:-}"
OPENAI_MODEL="${OPENAI_MODEL:-gpt-4.1}"
GEMINI_API_KEY="${GEMINI_API_KEY:-}"
GEMINI_MODEL="${GEMINI_MODEL:-gemini-1.5}"
CLAUDE_API_KEY="${CLAUDE_API_KEY:-}"
CLAUDE_MODEL="${CLAUDE_MODEL:-claude-3.1}"
MAX_DIFF_LINES="${MAX_DIFF_LINES:-2000}"

RED='\\033[0;31m'; GREEN='\\033[0;32m'; YELLOW='\\033[1;33m'; BLUE='\\033[0;34m'; NC='\\033[0m'

# Handle flags before any other logic
case "${1:-}" in
  --version|-v)
    echo "git-review v${VERSION}"
    exit 0
    ;;
  --help|-h)
    echo "Uso: git-review [branch-base]"
    echo ""
    echo "Opções:"
    echo "  --version, -v        Exibe a versão instalada"
    echo "  --help,    -h        Exibe esta ajuda"
    echo "  --update             Atualiza os scripts (git-review-update)"
    echo "  --uninstall          Desinstala scripts (git-review-uninstall)"
    echo ""
    echo "Variáveis de ambiente:"
    echo "  OPENAI_API_KEY       (obrigatório) Chave da API OpenAI"
    echo "  OPENAI_MODEL         (padrão: gpt-4o-mini) Modelo a utilizar"
    echo "  MAX_DIFF_LINES       (padrão: 2000) Limite de linhas do diff"
    echo "  API_PROVIDER         (openai|gemini|claude) Provedor de IA"
    echo "  DESCRIPTION_FILE     (opcional) Caminho para descrição do projeto"
    echo ""
    echo "Dependências:"
    echo "  curl, jq, bc, gh, glab"
    exit 0
    ;;
  --update)
    if command -v git-review-update >/dev/null 2>&1; then
      exec git-review-update
    elif [[ -x "$HOME/.local/share/git-review/git-review-update" ]]; then
      exec "$HOME/.local/share/git-review/git-review-update"
    elif [[ -x "$SCRIPT_DIR/git-review-update" ]]; then
      exec "$SCRIPT_DIR/git-review-update"
    else
      err "Comando git-review-update não encontrado. Execute install.sh ou verifique PATH."
      exit 1
    fi
    ;;
  --uninstall)
    if command -v git-review-uninstall >/dev/null 2>&1; then
      exec git-review-uninstall
    elif [[ -x "$HOME/.local/share/git-review/git-review-uninstall" ]]; then
      exec "$HOME/.local/share/git-review/git-review-uninstall"
    elif [[ -x "$SCRIPT_DIR/git-review-uninstall" ]]; then
      exec "$SCRIPT_DIR/git-review-uninstall"
    else
      err "Comando git-review-uninstall não encontrado. Execute install.sh ou verifique PATH."
      exit 1
    fi
    ;;
esac

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
log()  { echo -e "${BLUE}[review]${NC} $*"; }
warn() { echo -e "${YELLOW}[review]${NC} $*"; }
err()  { echo -e "${RED}[review]${NC} $*" >&2; }

# Carrega config externa (sobrepõe variáveis padrão, valores env tem prioridade)
if [[ -f "$CONFIG_FILE" ]]; then
  echo "[review] Carregando configuração: $CONFIG_FILE"
  # shellcheck source=/dev/null
  source "$CONFIG_FILE"
fi

# Exibe descrição do projeto, se disponível
if [[ -f "$DESCRIPTION_FILE" ]]; then
  echo "[review] Descrição do projeto ( $DESCRIPTION_FILE )":
  cat "$DESCRIPTION_FILE"
  echo ""
fi

# Valida provider AI e chave correspondentes
case "${API_PROVIDER,,}" in
  openai)
    API_PROVIDER="openai"
    if [[ -z "${OPENAI_API_KEY:-}" ]]; then
      err "OPENAI_API_KEY não definido. Use export OPENAI_API_KEY='sk-...' ou config."
      exit 1
    fi
    ;; 
  gemini)
    API_PROVIDER="gemini"
    if [[ -z "${GEMINI_API_KEY:-}" ]]; then
      err "GEMINI_API_KEY não definido. Use export GEMINI_API_KEY='...' ou config."
      exit 1
    fi
    ;; 
  claude)
    API_PROVIDER="claude"
    if [[ -z "${CLAUDE_API_KEY:-}" ]]; then
      err "CLAUDE_API_KEY não definido. Use export CLAUDE_API_KEY='...' ou config."
      exit 1
    fi
    ;; 
  *)
    err "API_PROVIDER inválido: ${API_PROVIDER}. Valores válidos: openai, gemini, claude."
    exit 1
    ;;
 esac

# --------------------------------------------------------------------------- #
# Validações
# --------------------------------------------------------------------------- #

if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  err "Este diretório não é um repositório Git."
  exit 1
fi

for cmd in curl jq bc; do
  if ! command -v "$cmd" &>/dev/null; then
    err "'$cmd' não encontrado. Instale com: sudo apt install $cmd"
    exit 1
  fi
done

# --------------------------------------------------------------------------- #
# Detecta branch base
# --------------------------------------------------------------------------- #
detect_base_branch() {
  # Argumento explícito tem prioridade
  if [[ $# -gt 0 && -n "${1:-}" ]]; then
    echo "$1"
    return 0
  fi

  # Tenta main e master tanto no remote quanto local
  for candidate in main master; do
    if git show-ref --verify --quiet "refs/remotes/origin/${candidate}" 2>/dev/null; then
      echo "$candidate"
      return 0
    fi
    if git show-ref --verify --quiet "refs/heads/${candidate}" 2>/dev/null; then
      echo "$candidate"
      return 0
    fi
  done

  return 1
}

# Captura o resultado fora do subshell para preservar exit code
if ! BASE_BRANCH=$(detect_base_branch "${1:-}") || [[ -z "$BASE_BRANCH" ]]; then
  err "Não foi possível detectar a branch base (main/master)."
  err "Passe a branch manualmente: review <branch-base>"
  exit 1
fi
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [[ "$CURRENT_BRANCH" == "$BASE_BRANCH" ]]; then
  warn "Você está na própria branch base ($BASE_BRANCH). Nada a comparar."
  exit 0
fi

log "Branch base:  $BASE_BRANCH"
log "Branch atual: $CURRENT_BRANCH"
log "Modelo:       $OPENAI_MODEL"

# --------------------------------------------------------------------------- #
# Gera o diff
# --------------------------------------------------------------------------- #
MERGE_BASE=$(git merge-base "origin/${BASE_BRANCH}" HEAD 2>/dev/null \
             || git merge-base "${BASE_BRANCH}" HEAD)

log "Gerando diff a partir do merge-base..."
DIFF_CONTENT=$(git diff "$MERGE_BASE" HEAD --)

if [[ -z "$DIFF_CONTENT" ]]; then
  warn "Nenhuma diferença encontrada em relação a '${BASE_BRANCH}'."
  exit 0
fi

DIFF_LINE_COUNT=$(echo "$DIFF_CONTENT" | wc -l)
log "Diff gerado: ${DIFF_LINE_COUNT} linhas"

if [[ "$DIFF_LINE_COUNT" -gt "$MAX_DIFF_LINES" ]]; then
  warn "Diff muito grande (${DIFF_LINE_COUNT} linhas). Truncando para ${MAX_DIFF_LINES} linhas."
  DIFF_CONTENT=$(echo "$DIFF_CONTENT" | head -n "$MAX_DIFF_LINES")
  DIFF_CONTENT+=$'\n\n[... diff truncado por limite de linhas ...]'
fi

# --------------------------------------------------------------------------- #
# Prompts
# --------------------------------------------------------------------------- #
if [[ -f "$SYSTEM_PROMPT_FILE" ]]; then
  SYSTEM_PROMPT="$(cat "$SYSTEM_PROMPT_FILE")"
else
  err "Arquivo de prompt não encontrado: $SYSTEM_PROMPT_FILE"
  err "Crie o arquivo ou defina SYSTEM_PROMPT_FILE apontando para o arquivo correto."
  exit 1
fi

USER_MESSAGE="Por favor, faça a revisão do seguinte git diff.

Branch base: ${BASE_BRANCH}
Branch revisada: ${CURRENT_BRANCH}

\`\`\`diff
${DIFF_CONTENT}
\`\`\`"

# --------------------------------------------------------------------------- #
# Chama a API de IA
# --------------------------------------------------------------------------- #
log "Enviando para a API de IA (${API_PROVIDER})..."
echo ""
echo -e "${GREEN}════════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}  Code Review: ${CURRENT_BRANCH} → ${BASE_BRANCH}${NC}"
echo -e "${GREEN}════════════════════════════════════════════════════════${NC}"
echo ""

case "$API_PROVIDER" in
  openai)
    PAYLOAD=$(jq -n \
      --arg model   "$OPENAI_MODEL" \
      --arg system  "$SYSTEM_PROMPT" \
      --arg user    "$USER_MESSAGE" \
      '{
        model: $model,
        temperature: 0,
        top_p: 1,
        messages: [
          { role: "system", content: $system },
          { role: "user",   content: $user }
        ]
      }')

    RESPONSE=$(curl -s https://api.openai.com/v1/chat/completions \
      -H "Content-Type: application/json" \
      -H "Authorization: Bearer ${OPENAI_API_KEY}" \
      -d "$PAYLOAD")

    ERROR=$(echo "$RESPONSE" | jq -r '.error.message // empty')
    if [[ -n "$ERROR" ]]; then
      err "Erro da API OpenAI: $ERROR"
      exit 1
    fi

    OUTPUT=$(echo "$RESPONSE" | jq -r '.choices[0].message.content // empty')
    TOKENS_IN=$(echo "$RESPONSE"  | jq -r '.usage.prompt_tokens // 0')
    TOKENS_OUT=$(echo "$RESPONSE" | jq -r '.usage.completion_tokens // 0')
    TOTAL=$(echo "$RESPONSE"      | jq -r '.usage.total_tokens // 0')
    COST=$(echo "scale=5; ($TOKENS_IN * 0.00000015) + ($TOKENS_OUT * 0.0000006)" | bc)
    ;;

  gemini)
    PROMPT="${SYSTEM_PROMPT}\n\n${USER_MESSAGE}"
    PAYLOAD=$(jq -n \
      --arg model "$GEMINI_MODEL" \
      --arg prompt "$PROMPT" \
      '{model: $model, prompt: $prompt, temperature: 0}')

    RESPONSE=$(curl -sS "https://gemini.googleapis.com/v1/models/${GEMINI_MODEL}:generateText" \
      -H "Content-Type: application/json" \
      -H "Authorization: Bearer ${GEMINI_API_KEY}" \
      -d "$PAYLOAD" 2>&1)

    if ! echo "$RESPONSE" | jq -e . >/dev/null 2>&1; then
      err "Erro: resposta inválida do Gemini (não JSON)."
      err "Respostas brutas: $RESPONSE"
      exit 1
    fi

    OUTPUT=$(echo "$RESPONSE" | jq -r '.candidates[0].output // .candidates[0].content // .output_text // .text // empty')

    if [[ -z "$OUTPUT" ]]; then
      ERR_DETAIL=$(echo "$RESPONSE" | jq -r '.error.message // .error // empty')
      if [[ -n "$ERR_DETAIL" ]]; then
        err "Gemini retornou erro: $ERR_DETAIL"
      else
        err "Gemini retornou JSON válido, mas não foi possível extrair o texto de saída."
        err "Resposta completa: $RESPONSE"
      fi
      exit 1
    fi

    TOKENS_IN=0
    TOKENS_OUT=0
    TOTAL=0
    COST=0
    ;;

  claude)
    PROMPT="\n\nSystem: ${SYSTEM_PROMPT}\n\nUser: ${USER_MESSAGE}\n\nAssistant:"
    PAYLOAD=$(jq -n \
      --arg model "$CLAUDE_MODEL" \
      --arg prompt "$PROMPT" \
      '{model: $model, prompt: $prompt, max_tokens_to_sample: 1024, temperature: 0}')

    RESPONSE=$(curl -s https://api.anthropic.com/v1/complete \
      -H "Content-Type: application/json" \
      -H "X-API-Key: ${CLAUDE_API_KEY}" \
      -d "$PAYLOAD")

    OUTPUT=$(echo "$RESPONSE" | jq -r '.completion // .completion.output // .completion.text // .completion.choices[0].text // .output_text // empty')
    TOKENS_IN=0
    TOKENS_OUT=0
    TOTAL=0
    COST=0
    ;;

  *)
    err "Provider desconhecido: ${API_PROVIDER}"
    exit 1
    ;;
esac

if [[ -z "${OUTPUT:-}" ]]; then
  err "Resposta vazia do provedor ${API_PROVIDER}."
  exit 1
fi

echo "$OUTPUT"

echo ""
echo -e "${GREEN}════════════════════════════════════════════════════════${NC}"

# --------------------------------------------------------------------------- #
# Opcional: Enviar comentário para MR/PR
# --------------------------------------------------------------------------- #
REMOTE_URL=$(git remote get-url origin 2>/dev/null)
PLATFORM=""
if [[ "$REMOTE_URL" =~ github\.com ]]; then
  PLATFORM="github"
elif [[ "$REMOTE_URL" =~ gitlab\.com ]]; then
  PLATFORM="gitlab"
else
  log "Plataforma não identificada (GitHub/GitLab). Pulando envio de comentário."
fi

if [[ -n "$PLATFORM" ]]; then
  log "Detectado: $PLATFORM"
  
  # Verificar se existe MR/PR para a branch atual
  MR_EXISTS=false
  if [[ "$PLATFORM" == "github" ]]; then
    if command -v gh >/dev/null 2>&1 && gh pr list --head "$CURRENT_BRANCH" --json number | jq -e 'length > 0' >/dev/null 2>&1; then
      MR_EXISTS=true
    fi
  elif [[ "$PLATFORM" == "gitlab" ]]; then
    if command -v glab >/dev/null 2>&1 && MR_ID=$(glab mr list --source-branch "$CURRENT_BRANCH" 2>/dev/null | grep -oP '^!\K\d+' | head -1) && [[ -n "$MR_ID" ]]; then
      MR_EXISTS=true
    fi
  fi
  
  if [[ "$MR_EXISTS" == true ]]; then
    COMMENT_FILE="/tmp/git-review-comment-$(date +%s).txt"
    COMMENT_BODY="$OUTPUT

---
Comentário gerado automaticamente usando $API_PROVIDER."
    echo "$COMMENT_BODY" > "$COMMENT_FILE"
    log "Comentário salvo em: $COMMENT_FILE"
    
    read -p "Deseja enviar este comentário para a MR/PR? (y/N): " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
      if [[ "$PLATFORM" == "github" ]]; then
        gh pr comment --body "$COMMENT_BODY"
        log "Comentário enviado para PR no GitHub."
      elif [[ "$PLATFORM" == "gitlab" ]]; then
        glab mr note "$MR_ID" -m "$COMMENT_BODY"
        log "Comentário enviado para MR $MR_ID no GitLab."
      fi
    else
      log "Comentário não enviado. Arquivo mantido em $COMMENT_FILE."
    fi
  else
    log "Nenhuma MR/PR encontrada para a branch '$CURRENT_BRANCH'."
  fi
fi

log "Tokens — entrada: ${TOKENS_IN:-0} | saída: ${TOKENS_OUT:-0} | total: ${TOTAL:-0}"
if [[ "$API_PROVIDER" == "openai" ]]; then
  log "Custo estimado: \$${COST} USD"
else
  log "Custo estimado: não disponível para ${API_PROVIDER} (use dados do provedor)"
fi
log "Revisão concluída."
