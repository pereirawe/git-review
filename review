#!/usr/bin/env bash
# =============================================================================
# review.sh — Code Review via OpenAI API (gpt-4o-mini)
# Uso: ./review.sh [branch-base]
#      Se omitido, detecta automaticamente main ou master.
#
# Configuração:
#   export OPENAI_API_KEY="sk-..."      # obrigatório
#   export OPENAI_MODEL="gpt-4o-mini"  # opcional
#   export MAX_DIFF_LINES=2000          # opcional
# =============================================================================

set -euo pipefail

# OPENAI_API_KEY="${OPENAI_API_KEY:-}"
OPENAI_MODEL="${OPENAI_MODEL:-gpt-4o-mini}"
MAX_DIFF_LINES="${MAX_DIFF_LINES:-2000}"

OPENAI_API_KEY="${OPENAI_API_KEY:-}"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
log()  { echo -e "${BLUE}[review]${NC} $*"; }
warn() { echo -e "${YELLOW}[review]${NC} $*"; }
err()  { echo -e "${RED}[review]${NC} $*" >&2; }

# --------------------------------------------------------------------------- #
# Validações
# --------------------------------------------------------------------------- #
if [[ -z "$OPENAI_API_KEY" ]]; then
  err "Variável OPENAI_API_KEY não definida."
  err "Execute: export OPENAI_API_KEY='sk-...'"
  exit 1
fi

if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  err "Este diretório não é um repositório Git."
  exit 1
fi

for cmd in curl jq bc; do
  if ! command -v "$cmd" &>/dev/null; then
    err "'$cmd' não encontrado. Instale com: sudo apt install $cmd"
    exit 1
  fi
done

# --------------------------------------------------------------------------- #
# Detecta branch base
# --------------------------------------------------------------------------- #
detect_base_branch() {
  if [[ $# -gt 0 ]]; then echo "$1"; return; fi
  for candidate in main master; do
    if git show-ref --verify --quiet "refs/remotes/origin/${candidate}" 2>/dev/null; then
      echo "$candidate"; return
    fi
    if git show-ref --verify --quiet "refs/heads/${candidate}" 2>/dev/null; then
      echo "$candidate"; return
    fi
  done
  err "Não foi possível detectar a branch base (main/master)."
  err "Passe a branch manualmente: ./review.sh <branch-base>"
  exit 1
}

BASE_BRANCH=$(detect_base_branch "${1:-}")
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [[ "$CURRENT_BRANCH" == "$BASE_BRANCH" ]]; then
  warn "Você está na própria branch base ($BASE_BRANCH). Nada a comparar."
  exit 0
fi

log "Branch base:  $BASE_BRANCH"
log "Branch atual: $CURRENT_BRANCH"
log "Modelo:       $OPENAI_MODEL"

# --------------------------------------------------------------------------- #
# Gera o diff
# --------------------------------------------------------------------------- #
MERGE_BASE=$(git merge-base "origin/${BASE_BRANCH}" HEAD 2>/dev/null \
             || git merge-base "${BASE_BRANCH}" HEAD)

log "Gerando diff a partir do merge-base..."
DIFF_CONTENT=$(git diff "$MERGE_BASE" HEAD --)

if [[ -z "$DIFF_CONTENT" ]]; then
  warn "Nenhuma diferença encontrada em relação a '${BASE_BRANCH}'."
  exit 0
fi

DIFF_LINE_COUNT=$(echo "$DIFF_CONTENT" | wc -l)
log "Diff gerado: ${DIFF_LINE_COUNT} linhas"

if [[ "$DIFF_LINE_COUNT" -gt "$MAX_DIFF_LINES" ]]; then
  warn "Diff muito grande (${DIFF_LINE_COUNT} linhas). Truncando para ${MAX_DIFF_LINES} linhas."
  DIFF_CONTENT=$(echo "$DIFF_CONTENT" | head -n "$MAX_DIFF_LINES")
  DIFF_CONTENT+=$'\n\n[... diff truncado por limite de linhas ...]'
fi

# --------------------------------------------------------------------------- #
# Prompts
# --------------------------------------------------------------------------- #
SYSTEM_PROMPT='Persona: Senior Tech Lead & Code Reviewer

Você é um revisor de código sênior focado em manter a qualidade do software, segurança e legibilidade. Sua atuação deve ser marcada por um olhar pragmático e uma postura de mentoria para o desenvolvedor. Evitando refatorações inúteis e sempre procurando boas práticas, escalabilidade e equilíbrio para evitar o overengineering.

📥 Input
Você receberá um git diff ou o conteúdo de uma Merge Request (MR).

🎯 Objetivos da Revisão

1. Contextualizar: Explique brevemente o que você entendeu que a alteração está tentando resolver.
2. Abordagem Sugerida: Se houver melhorias, sugira uma abordagem em vez de apenas apontar o erro.
3. Focar no "Porquê": Os comentários do programador devem explicar a motivação por trás da sugestão (ex: performance, segurança, manutenção) e não apenas descrever o código.
4. Pragmatismo: Evite solicitar refatorações completas ou mudanças arquiteturais profundas, a menos que o código atual seja crítico, contenha bugs ou fira gravemente os princípios do projeto.
5. Manutenção: Seja cauteloso ao sugerir mudanças que possam afetar negativamente a facilidade de manutenção futura.
6. Boas Práticas: Incentive o uso de constantes, nomenclatura semântica, funções coesas e classes bem estruturadas.

🌐 Regras de Linguagem
* Código: Todo código sugerido (nomes de variáveis, funções, classes) deve estar estritamente em Inglês.
* Comunicação: O texto explicativo, labels e os comentários da MR devem ser escritos em Português.

📄 Formato de Saída Esperado

1. Resumo da Revisão
* Contexto: [Breve descrição técnica do que as mudanças realizam]
* Avaliação Geral: [Feedback rápido e objetivo sobre a saúde da MR]

2. Comentários de Alteração
Para cada ponto de melhoria crítico identificado, siga o formato:
* Descrição: [Resumo do ponto identificado]
* Arquivo/Linha: [Nome do arquivo e linha aproximada]
* Sugestão:
```
// Código sugerido aqui (em Inglês)
```
* Racional (O Porquê): [Explicação em Português do motivo da mudança e qual o benefício esperado]

* Considerações Finais
* ✅ Pontos fortes: [Destaque o que foi bem implementado]
* ⚠️ Pontos de atenção: [Alertas sobre possíveis débitos técnicos ou riscos futuros]'

USER_MESSAGE="Por favor, faça a revisão do seguinte git diff.

Branch base: ${BASE_BRANCH}
Branch revisada: ${CURRENT_BRANCH}

\`\`\`diff
${DIFF_CONTENT}
\`\`\`"

# --------------------------------------------------------------------------- #
# Chama a API da OpenAI
# --------------------------------------------------------------------------- #
log "Enviando para a API da OpenAI..."
echo ""
echo -e "${GREEN}════════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}  Code Review: ${CURRENT_BRANCH} → ${BASE_BRANCH}${NC}"
echo -e "${GREEN}════════════════════════════════════════════════════════${NC}"
echo ""

PAYLOAD=$(jq -n \
  --arg model   "$OPENAI_MODEL" \
  --arg system  "$SYSTEM_PROMPT" \
  --arg user    "$USER_MESSAGE" \
  '{
    model: $model,
    temperature: 0.2,
    messages: [
      { role: "system", content: $system },
      { role: "user",   content: $user }
    ]
  }')

RESPONSE=$(curl -s https://api.openai.com/v1/chat/completions \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer ${OPENAI_API_KEY}" \
  -d "$PAYLOAD")

ERROR=$(echo "$RESPONSE" | jq -r '.error.message // empty')
if [[ -n "$ERROR" ]]; then
  err "Erro da API OpenAI: $ERROR"
  exit 1
fi

echo "$RESPONSE" | jq -r '.choices[0].message.content'

echo ""
echo -e "${GREEN}════════════════════════════════════════════════════════${NC}"

TOKENS_IN=$(echo "$RESPONSE"  | jq -r '.usage.prompt_tokens // 0')
TOKENS_OUT=$(echo "$RESPONSE" | jq -r '.usage.completion_tokens // 0')
TOTAL=$(echo "$RESPONSE"      | jq -r '.usage.total_tokens // 0')
COST=$(echo "scale=5; ($TOKENS_IN * 0.00000015) + ($TOKENS_OUT * 0.0000006)" | bc)

log "Tokens — entrada: ${TOKENS_IN} | saída: ${TOKENS_OUT} | total: ${TOTAL}"
log "Custo estimado: \$${COST} USD"
log "Revisão concluída."