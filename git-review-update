#!/bin/bash
set -e

# ---------------------------------------------
#  git-review-update
#  Faz git pull no repositório instalado.
# ---------------------------------------------

INSTALL_DIR="$HOME/.local/share/git-review"

# -- helpers -----------------------------------

info()    { printf '\033[1;34m[INFO]\033[0m  %s\n' "$*"; }
success() { printf '\033[1;32m[OK]\033[0m    %s\n' "$*"; }
warn()    { printf '\033[1;33m[WARN]\033[0m  %s\n' "$*"; }
error()   { printf '\033[1;31m[ERROR]\033[0m %s\n' "$*" >&2; exit 1; }

# -- main --------------------------------------

info "Verificando atualização do git-review..."

# 1. Verificar se está instalado
if [ ! -d "$INSTALL_DIR/.git" ]; then
  error "Repositório não encontrado em $INSTALL_DIR. Execute o instalador primeiro:
  curl -fsSL https://raw.githubusercontent.com/pereirawe/git-review/refs/heads/main/install.sh | sh"
fi

# 2. Versão instalada
LOCAL_VERSION=$(grep -m1 '^VERSION=' "$INSTALL_DIR/git-review" 2>/dev/null | sed 's/VERSION="\(.*\)"/\1/')
info "Versão instalada: v${LOCAL_VERSION:-desconhecida}"

# 3. Fazer pull
info "Buscando atualizações..."
if ! OUTPUT=$(git -C "$INSTALL_DIR" pull --ff-only 2>&1); then
  echo "Saída do git pull:"
  echo "$OUTPUT"
  error "Falha ao atualizar. Verifique sua conexão e se o repositório está válido."
fi

if echo "$OUTPUT" | grep -q "Already up to date"; then
  success "git-review já está na versão mais recente."
  exit 0
fi

# 4. Garantir permissões após o pull
chmod +x "$INSTALL_DIR/git-review"
chmod +x "$INSTALL_DIR/git-review-update"
chmod +x "$INSTALL_DIR/git-review-uninstall"

# 5. Versão após atualização
NEW_VERSION=$(grep -m1 '^VERSION=' "$INSTALL_DIR/git-review" 2>/dev/null | sed 's/VERSION="\(.*\)"/\1/')

echo ""
success "git-review atualizado: v${LOCAL_VERSION:-?} → v${NEW_VERSION:-?}"
info    "Execute 'git-review --version' para confirmar."
