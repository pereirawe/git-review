#!/bin/sh
set -e

# ─────────────────────────────────────────────────────────────────────────────
#  git-review-update
#  Verifica a versão instalada, compara com a remota e atualiza se necessário.
# ─────────────────────────────────────────────────────────────────────────────

BASE_URL="https://gitlab.com/-/snippets/5965695/raw/main"
INSTALL_DIR="$HOME/.local/bin"
MAIN_SCRIPT="$INSTALL_DIR/git-review"

# ── helpers ───────────────────────────────────────────────────────────────────

info()    { printf '\033[1;34m[INFO]\033[0m  %s\n' "$*"; }
success() { printf '\033[1;32m[OK]\033[0m    %s\n' "$*"; }
warn()    { printf '\033[1;33m[WARN]\033[0m  %s\n' "$*"; }
error()   { printf '\033[1;31m[ERROR]\033[0m %s\n' "$*" >&2; exit 1; }

# ── version helpers ───────────────────────────────────────────────────────────

extract_version() {
  grep -m1 '^VERSION=' "$1" 2>/dev/null | sed 's/VERSION="\(.*\)"/\1/'
}

# Compara duas versões semânticas (MAJOR.MINOR.PATCH).
# Exibe: 0 = remota mais nova | 1 = iguais | 2 = local mais nova
version_compare() {
  [ "$1" = "$2" ] && { echo 1; return; }
  _norm() { echo "$1" | awk -F. '{ printf "%06d%06d%06d\n", $1, $2, $3 }'; }
  local a b
  a=$(_norm "$1")
  b=$(_norm "$2")
  if [ "$a" -lt "$b" ]; then
    echo 0
  elif [ "$a" -gt "$b" ]; then
    echo 2
  else
    echo 1
  fi
}

# ── download e instala um script ──────────────────────────────────────────────

install_script() {
  local name="$1"
  local dest="$INSTALL_DIR/$name"
  local tmp
  tmp=$(mktemp /tmp/"$name".XXXXXX)
  trap 'rm -f "$tmp"' EXIT
  curl -fsSL "$BASE_URL/$name" -o "$tmp" \
    || error "Falha ao baixar $name."
  rm -f "$dest"
  cp "$tmp" "$dest"
  chmod +x "$dest"
}

# ── main ──────────────────────────────────────────────────────────────────────

info "Verificando atualização do git-review..."

# 1. Verificar se está instalado
if [ ! -f "$MAIN_SCRIPT" ]; then
  error "git-review não encontrado em $MAIN_SCRIPT. Execute o instalador primeiro:
  curl -fsSL $BASE_URL/install.sh | sh"
fi

# 2. Versão instalada localmente
LOCAL_VERSION=$(extract_version "$MAIN_SCRIPT")
if [ -z "$LOCAL_VERSION" ]; then
  warn "Não foi possível determinar a versão local. Forçando atualização..."
  LOCAL_VERSION="0.0.0"
fi
info "Versão instalada: v${LOCAL_VERSION}"

# 3. Baixar o script remoto para verificar a versão
TMP_MAIN=$(mktemp /tmp/git-review.XXXXXX)
trap 'rm -f "$TMP_MAIN"' EXIT

info "Consultando versão remota..."
curl -fsSL "$BASE_URL/git-review" -o "$TMP_MAIN" \
  || error "Falha ao conectar. Verifique sua conexão."

# 4. Versão remota
REMOTE_VERSION=$(extract_version "$TMP_MAIN")
if [ -z "$REMOTE_VERSION" ]; then
  error "Não foi possível determinar a versão remota."
fi
info "Versão disponível: v${REMOTE_VERSION}"

# 5. Comparar versões
CMP=$(version_compare "$LOCAL_VERSION" "$REMOTE_VERSION")

case "$CMP" in
  1)
    success "git-review já está na versão mais recente (v${LOCAL_VERSION})."
    exit 0
    ;;
  2)
    warn "Versão local (v${LOCAL_VERSION}) é mais nova que a remota (v${REMOTE_VERSION}). Nada a fazer."
    exit 0
    ;;
  0)
    info "Nova versão disponível: v${LOCAL_VERSION} → v${REMOTE_VERSION}"
    ;;
esac

# 6. Atualizar todos os scripts
info "Atualizando git-review..."
rm -f "$INSTALL_DIR/git-review"
cp "$TMP_MAIN" "$INSTALL_DIR/git-review"
chmod +x "$INSTALL_DIR/git-review"

info "Atualizando git-review-update..."
install_script "git-review-update"

info "Atualizando git-review-uninstall..."
install_script "git-review-uninstall"

echo ""
success "git-review atualizado: v${LOCAL_VERSION} → v${REMOTE_VERSION}"
info    "Execute 'git-review --version' para confirmar."
