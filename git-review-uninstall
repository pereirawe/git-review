#!/bin/sh
set -e

# ─────────────────────────────────────────────
#  git-review-uninstall
# ─────────────────────────────────────────────

INSTALL_DIR="$HOME/.local/share/git-review"
BIN_LINK="$HOME/.local/bin/git-review"

info()    { printf '\033[1;34m[INFO]\033[0m  %s\n' "$*"; }
success() { printf '\033[1;32m[OK]\033[0m    %s\n' "$*"; }
warn()    { printf '\033[1;33m[WARN]\033[0m  %s\n' "$*"; }

info "Desinstalando git-review..."

# 1. Remover o repositório clonado
if [ -d "$INSTALL_DIR" ]; then
  rm -rf "$INSTALL_DIR"
  success "Removido: $INSTALL_DIR"
else
  warn "$INSTALL_DIR não encontrado, pulando."
fi

# 2. Remover o symlink do PATH
if [ -L "$BIN_LINK" ] || [ -f "$BIN_LINK" ]; then
  rm -f "$BIN_LINK"
  success "Removido: $BIN_LINK"
else
  warn "$BIN_LINK não encontrado, pulando."
fi

echo ""
success "git-review desinstalado com sucesso."
info    "Para remover a chave da API do seu shell, edite ~/.bashrc ou ~/.zshrc"
info    "e remova as linhas com API_KEY que você tiver exportado manualmente."
