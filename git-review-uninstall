#!/bin/sh
set -e

# ─────────────────────────────────────────────
#  git-review-uninstall
# ─────────────────────────────────────────────

INSTALL_DIR="$HOME/.local/bin"

info()    { printf '\033[1;34m[INFO]\033[0m  %s\n' "$*"; }
success() { printf '\033[1;32m[OK]\033[0m    %s\n' "$*"; }
warn()    { printf '\033[1;33m[WARN]\033[0m  %s\n' "$*"; }

info "Desinstalando git-review..."

REMOVED=0

for script in git-review git-review-update git-review-uninstall; do
  target="$INSTALL_DIR/$script"
  if [ -f "$target" ]; then
    rm -f "$target"
    success "Removido: $target"
    REMOVED=$((REMOVED + 1))
  else
    warn "$target não encontrado, pulando."
  fi
done

echo ""
if [ "$REMOVED" -gt 0 ]; then
  success "git-review desinstalado com sucesso."
else
  warn "Nenhum arquivo encontrado. Já estava desinstalado?"
fi

info "Para remover a chave da API, rode: unset OPENAI_API_KEY"
info "E remova a linha do OPENAI_API_KEY do seu ~/.bashrc ou ~/.zshrc."
