# git-review configuration
# Copie para ~/.git-review/config ou defina GIT_REVIEW_CONFIG e SYSTEM_PROMPT_FILE manualmente.

API_PROVIDER=openai  # openai|gemini|claude

# OpenAI
OPENAI_API_KEY="YOUR_OPENAI_KEY"
OPENAI_MODEL="gpt-4.1"

# Gemini (exemplo)
GEMINI_API_KEY="YOUR_GEMINI_KEY"
GEMINI_MODEL="gemini-1.5"

# Claude (exemplo Anthropic)
CLAUDE_API_KEY="YOUR_CLAUDE_KEY"
CLAUDE_MODEL="claude-3.1"

# Geral
MAX_DIFF_LINES=2000

# Opcional, local do prompt (por default, system_prompt.txt ao lado do script)
# SYSTEM_PROMPT_FILE="$HOME/.git-review/system_prompt.txt"
